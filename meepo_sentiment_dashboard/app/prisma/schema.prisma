generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model SentimentData {
  id                   Int      @id @default(autoincrement())
  url                  String
  timestamp            DateTime
  content              String
  author               String
  subreddit            String
  postTitle            String   @map("post_title")
  postType             String   @default("post") @map("post_type")
  upvotes              Int      @default(0)
  numComments          Int      @default(0) @map("num_comments")
  sentimentScore       Float    @map("sentiment_score")
  sentimentLabel       String   @map("sentiment_label")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  brandId              Int      @map("brand_id")
  isNegativeAboutBrand Boolean  @map("is_negative_about_brand")
  matchedKeywords      String[] @default([]) @map("matched_keywords")
  intentType           String?  @map("intent_type")
  intentScore          Float?   @map("intent_score")
  brand                Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([url, brandId])
  @@index([sentimentLabel])
  @@index([subreddit])
  @@index([timestamp])
  @@index([isNegativeAboutBrand])
  @@index([brandId])
  @@index([brandId, subreddit])
  @@index([upvotes])
  @@index([intentType])
  @@map("sentiment_data")
}

model Brand {
  id               Int              @id @default(autoincrement())
  name             String
  website          String?
  description      String?
  category         String?
  userId           String
  subscriptionTier String           @default("trial") @map("subscription_tier")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  city             String?
  country          String?
  focusLocal       Boolean          @default(false) @map("focus_local")
  state            String?
  keywords         BrandKeyword[]
  subreddits       BrandSubreddit[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentimentData    SentimentData[]
  refreshLogs      RefreshLog[]

  @@index([userId])
  @@index([subscriptionTier])
  @@index([isActive])
  @@index([focusLocal])
  @@index([city])
  @@map("brands")
}

model BrandSubreddit {
  id        Int      @id @default(autoincrement())
  brandId   Int      @map("brand_id")
  subreddit String
  isActive  Boolean  @default(true) @map("is_active")
  priority  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, subreddit])
  @@index([brandId])
  @@index([isActive])
  @@map("brand_subreddits")
}

model BrandKeyword {
  id       Int      @id @default(autoincrement())
  brandId  Int      @map("brand_id")
  keyword  String
  type     String   @default("track")
  category String?
  isActive Boolean  @default(true) @map("is_active")
  addedAt  DateTime @default(now()) @map("added_at")
  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, keyword])
  @@index([brandId])
  @@index([isActive])
  @@index([type])
  @@map("brand_keywords")
}

model RefreshLog {
  id          Int      @id @default(autoincrement())
  brandId     Int?     @map("brand_id")
  refreshedAt DateTime @default(now())
  newRecords  Int      @default(0)
  status      String
  errorMsg    String?  @map("error_msg")

  brand       Brand?   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([refreshedAt])
  @@index([brandId])
  @@map("refresh_logs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        Account[]
  sessions        Session[]
  brands          Brand[]
  researchQueries ResearchQuery[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ResearchQuery {
  id              Int              @id @default(autoincrement())
  name            String
  description     String?
  subreddits      String[]
  keywords        String[]
  excludeKeywords String[]
  dateFrom        DateTime?
  dateTo          DateTime?
  minScore        Int?
  maxResults      Int              @default(1000)
  userId          String
  status          String           @default("pending")
  progressMessage String?
  totalResults    Int              @default(0)
  painPointsFound Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  results         ResearchResult[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("research_queries")
}

model ResearchResult {
  id                  Int           @id @default(autoincrement())
  queryId             Int
  url                 String
  title               String
  content             String
  author              String
  subreddit           String
  score               Int
  numComments         Int
  timestamp           DateTime
  sentimentScore      Float
  sentimentLabel      String
  painPointCategory   String?
  painPointSeverity   String?
  keywordsFound       String[]
  relevanceScore      Float
  businessOpportunity String?
  createdAt           DateTime      @default(now())
  query               ResearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@index([subreddit])
  @@index([painPointCategory])
  @@index([sentimentLabel])
  @@index([relevanceScore])
  @@index([timestamp])
  @@map("research_results")
}
